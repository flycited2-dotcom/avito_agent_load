# Avito
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=          # перевыпустить после первого боевого теста
# LLM (Фаза 2)
ANTHROPIC_API_KEY=
# Источник данных — БД сайта SplitHome (read-only), значения из /opt/oasis/.env
DB_HOST=localhost
DB_PORT=5432
DB_NAME=splithome
DB_USER=splithome
DB_PASSWORD=
# Опт Бриза напрямую из Breez API (Фаза 2), значения из /opt/oasis/.env
BREEZ_BASE_URL=https://api.breez.ru/v1/
BREEZ_AUTH_HEADER=
# JAC (4-й поставщик) — JSON, который скрапер ostatki_mdv_b2b заливает на VPS
JAC_STOCK_JSON=/opt/splithub_api_telegram/data/jac_stock_latest.json
# Алерты (Фаза 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=1264067528
# Публичный URL фида (его заберёт Avito Автозагрузка)
FEED_PUBLIC_URL=
